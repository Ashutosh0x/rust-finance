# ==============================================================================
# RustForge Configuration Environment
# ==============================================================================

# --- Database / Infrastructure ---
POSTGRES_USER=rustforge
POSTGRES_PASSWORD=rustforge_secret
POSTGRES_DB=rustforge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# DragonflyDB Connection
REDIS_URL=redis://localhost:6379

# --- Keys & APIs ---
# Anthropic inference (Opus 4.6 & Sonnet 4.6)
ANTHROPIC_API_KEY=sk-ant-api03-xxx...
# Fix API keys
FINNHUB_API_KEY=xxx...
ALPACA_API_KEY=PKXXXX...
ALPACA_SECRET_KEY=SKXXXX...

# --- Solana RPC Failover Config ---
HELIUS_API_KEY=xxx...
QUICKNODE_RPC_URL=https://...
TRITON_RPC_URL=https://...

# Wallet & Live Trading
SOL_PRIVATE_KEY=xxx...
USE_MOCK=true
EXECUTION_MODE=dry_run   # 'dry_run' | 'live'

# --- Limits ---
MAX_DRAWDOWN=0.05
VAR_95_LIMIT=0.02
